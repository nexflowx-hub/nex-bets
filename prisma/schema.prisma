generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Match {
  id          String       @id @default(cuid())
  homeTeam    String
  awayTeam    String
  homeScore   Int          @default(0)
  awayScore   Int          @default(0)
  status      String       @default("upcoming") // upcoming, live, finished
  round       String
  date        String
  time        String       @default("")
  venue       String       @default("")
  odds        OddsMarket[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model OddsMarket {
  id        String @id @default(cuid())
  matchId   String
  type      String
  label     String
  homeOdds  Float  @default(0)
  drawOdds  Float  @default(0)
  awayOdds  Float  @default(0)
  yesOdds   Float  @default(0)
  noOdds    Float  @default(0)
  overOdds  Float  @default(0)
  underOdds Float  @default(0)
  match     Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id            String        @id @default(cuid())
  whatsapp      String        @unique
  name          String?
  balance       Float         @default(0)
  bonusBalance  Float         @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  bets          Bet[]
  transactions  Transaction[]
  winnerBets    WinnerBet[]
}

model Bet {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  selections      String
  totalOdds       Float
  totalStake      Float
  potentialReturn Float
  status          String   @default("pending")
  betType         String   @default("match")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String
  amount      Float
  description String?
  pixCode     String?
  status      String   @default("pending")
  createdAt   DateTime @default(now())
}

model WinnerBet {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  team      String
  amount    Float
  betValue  Float
  status    String   @default("active")
  createdAt DateTime @default(now())
}
